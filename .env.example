# ── Núcleo (sin default: la app falla si faltan) ─────────────────────────────
SECRET_KEY=cambia-esto-en-cada-entorno
SECRET_KEY_FERNET=genera-una-clave-fernet-distinta-de-SECRET_KEY
DEBUG=True
# El prefijo `.localhost` cubre `localhost` Y todos sus subdominios (admin./xenty./<tenant>.).
# Es OBLIGATORIO en dev: el control plane (superadmin-backend) valida el Host contra esta lista y,
# sin el subdominio permitido, django-tenants devuelve 404 en login super-admin / alta de tenants.
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
# Allowlist de IPs para /admin/ (vacío = sin restricción en dev)
ADMIN_IP_ALLOWLIST=
# Dominio base para subdominios de tenant en el alta self-service (dev: localhost)
TENANT_BASE_DOMAIN=localhost

# Super-admin del control plane: se auto-siembra al arrancar (bootstrap_superadmin) si no existe
# ninguno y ambas variables están definidas. Se crea con MFA OBLIGATORIO (el primer login exige
# enrolar + verificar el 2º factor). Vacías = no se auto-crea (usar `crear_superadmin`).
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NOMBRE=Super Admin

# WebAuthn / FIDO2 (2º factor MFA). RP_ID = dominio registrable (sin puerto/esquema).
# ORIGINS = orígenes completos permitidos (con esquema y puerto), separados por coma.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Xenty Acceso
WEBAUTHN_ORIGINS=http://localhost:8080,http://localhost:8081

# ── Base de datos ────────────────────────────────────────────────────────────
DB_NAME=xenty_acceso
DB_USER=xenty
DB_PASSWORD=xenty
DB_HOST=postgres
DB_PORT=5432

# ── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── CORS (las 3 SPAs) ────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:5175,http://localhost:5176

# ── Email ────────────────────────────────────────────────────────────────────
# Config compartida por data plane y control plane (el signup/verificación corre en el control
# plane). Dev con Mailpit: SMTP plano en :1025, sin TLS/SSL. Para SMTP real (Gmail): EMAIL_HOST=
# smtp.gmail.com, EMAIL_PORT=587, EMAIL_USE_TLS=True, y USER/PASSWORD (app password sin espacios).
EMAIL_HOST=mailpit
EMAIL_PORT=1025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@xenty.mx

# ── Integraciones (vacío = deshabilitado / sandbox) ──────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://app.xenty.mx/billing/ok
STRIPE_CANCEL_URL=https://app.xenty.mx/billing/cancel
ANTHROPIC_API_KEY=
ULTRAMSG_TOKEN=
ULTRAMSG_INSTANCE_ID=
# Connector (XCC) opcional — solo si levantas el perfil "connector"
# (docker compose --profile connector up -d --build connector). Debe ser IDÉNTICO al hmac_secret que
# el super-admin guarda en la pantalla Comunicaciones. En local, la URL base del Connector es
# http://connector:8090 (mismo network); no uses host.docker.internal ni 127.0.0.1.
XCC_HMAC_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SAT_EFOS_UPDATE_EVERY_MONTHS=1
SAT_EFOS_CSV_URL=
SAT_EFOS_ESTATUS_BLOQUEANTES=Definitivo,Presunto
SENTRY_DSN=

# NUNCA subas el .env real al repo. Este .env.example se mantiene completo (DoD F0/F8).
